# =====================================================
# .env.development.example — BU DOSYA GIT'E GİRER
# Gerçek key'leri .env.local'a koy (git'e girmez)
# =====================================================

# Supabase — listur-dev projesi
# Dashboard: https://supabase.com/dashboard/project/[proje-id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://[dev-proje-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # SADECE server-side — asla NEXT_PUBLIC_ yapma

# OpenAI — GPT-4o için
# platform.openai.com/api-keys
OPENAI_API_KEY=sk-...  # SADECE server-side — asla NEXT_PUBLIC_ yapma

# Cron Job — Vercel cron auth token
CRON_SECRET=your-random-secret-here  # SADECE server-side — asla NEXT_PUBLIC_ yapma

# Uygulama
NEXT_PUBLIC_APP_URL=http://localhost:3000
