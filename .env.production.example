# =====================================================
# .env.production.example — BU DOSYA GIT'E GİRER
# Gerçek key'leri Vercel Dashboard'dan gir (Settings > Environment Variables)
# =====================================================

# Supabase — listur-prod projesi
NEXT_PUBLIC_SUPABASE_URL=https://[prod-proje-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # SADECE server-side — asla NEXT_PUBLIC_ yapma

# OpenAI — GPT-4o için
OPENAI_API_KEY=sk-...  # SADECE server-side — asla NEXT_PUBLIC_ yapma

# Cron Job — Vercel cron auth token
CRON_SECRET=your-random-secret-here  # SADECE server-side — asla NEXT_PUBLIC_ yapma

# Uygulama
NEXT_PUBLIC_APP_URL=https://listur.bilalabic.com
